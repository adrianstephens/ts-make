{
	"name": "@isopodlabs/make",
	"version": "0.5.2",
	"description": "A package for reading and running makefiles with TypeScript.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/adrianstephens/ts-make.git"
	},
	"main": "dist/index.js",
	"bin": {
		"make": "dist/cli.js"
	},
	"exports": {
		".": "./dist/index.js",
		"./cli": "./dist/cli.js"
	},
	"files": [
		"dist/**/*.{js,d.ts}",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"watch": "tsc -watch -p ./",
		"lint": "eslint \"src/**/*.ts\"",
		"patch": "ts-patch install"
	},
	"keywords": [
		"makefile",
		"parser",
		"gnu make",
		"build",
		"typescript",
		"nodejs"
	],
	"author": "Adrian Stephens",
	"license": "MIT"
}
